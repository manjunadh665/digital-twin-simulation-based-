<launch>
    <let name="urdf_path" value="$(find-pkg-share digital_twin)/urdf/digital_twin.urdf.xacro" />
    <let name="gazebo_bridge_path" value="$(find-pkg-share digital_twin)/config/gazebo_bridge.yaml"/>
    <let name="rviz_config_path" value="$(find-pkg-share digital_twin)/rviz/rviz_config.rviz"/>

    <node pkg="robot_state_publisher" exec="robot_state_publisher" >
        <param name="robot_description" value="$(command 'xacro $(var urdf_path)')" />
    </node>

    <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py" >
        <!-- <arg name="gz_args" value="$(find-pkg-share my_robot_bringup)/worlds/test_world.sdf"/> -->
        <arg name="gz_args" value="empty.sdf -r"/> 
    </include>

    <node pkg="ros_gz_sim" exec="create" args="-topic robot_description" />

    <node pkg="ros_gz_bridge" exec="parameter_bridge" >
        <param name="config_file" value="$(var gazebo_bridge_path)"/>
    </node>

    <node pkg="digital_twin" exec="anomaly_detector" output="screen"/>

    <node pkg="foxglove_bridge" exec="foxglove_bridge" output="screen">
        <param name="port" value="8765"/>
    </node>

    <executable
        cmd="ros2 control load_controller --set-state active joint_state_broadcaster"
        output="screen"
        launch-prefix="bash -c 'sleep 3 &amp;&amp; $0 $@'"/>

    <executable
        cmd="ros2 control load_controller --set-state active arm_controller"
        output="screen"
        launch-prefix="bash -c 'sleep 4 &amp;&amp; $0 $@'"/>

    <executable
        cmd="/home/hyndavi/ros2_ws/install/digital_twin/lib/digital_twin/record_bag.sh"
        output="screen"/>
        
    <executable
        cmd="foxglove-studio" output="screen" launch-prefix="bash -c 'sleep 3 &amp;&amp; $0 $@'"/>

    <node pkg="rviz2" exec="rviz2" output="screen" args="-d $(var rviz_config_path)"/>
</launch>